# Zareb Frontend — Environment Configuration
#
# Copy this file to frontend/.env.local for local dev.
# .env.local is gitignored; never commit secrets.

# Backend API URL — change to your Railway URL in production:
VITE_API_URL=http://localhost:8000

# reCAPTCHA site key (optional — matches backend RECAPTCHA_SITE_KEY)
# VITE_RECAPTCHA_SITE_KEY=6Lc...

# Zareb — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored; never commit secrets.

# ── AI Provider ──────────────────────────────────────────────
AI_PROVIDER=groq                                    # "groq" or "claude"
GROQ_API_KEY=                                        # Get free at https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile

# Claude (fallback — requires Anthropic account)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=2000

# ── Database ────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite:///./zareb.db
# PostgreSQL (production — Railway provides this automatically):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/zareb

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string-at-least
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
# Site URL for magic links (frontend URL):
SITE_URL=http://localhost:5173

# ── File Storage (Cloudinary) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email (magic link delivery — optional) ─────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@zareb.app

# ── reCAPTCHA (optional) ────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

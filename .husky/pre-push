#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# ── Branch naming convention ────────────────────────────
BRANCH_NAME=$(git symbolic-ref HEAD 2>/dev/null | cut -d'/' -f3-)
if [ -n "$BRANCH_NAME" ] && [ "$BRANCH_NAME" != "main" ] && [ "$BRANCH_NAME" != "master" ] && [ "$BRANCH_NAME" != "develop" ]; then
  if ! echo "$BRANCH_NAME" | grep -qE '^(feature|fix|hotfix|chore|docs|refactor)/[a-z0-9-]+$'; then
    echo ""
    echo "❌ Bad branch name: '$BRANCH_NAME'"
    echo "   Use: feature/xxx, fix/xxx, hotfix/xxx, chore/xxx, docs/xxx, refactor/xxx"
    exit 1
  fi
fi

# ── Frontend checks ─────────────────────────────────────
cd frontend
npm test 2>/dev/null || echo "No tests configured"
npm run build --if-present

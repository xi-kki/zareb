# Zareb Backend Environment Variables
# ─────────────────────────────────────────

# Mode
DEBUG=false                              # Set to true for dev (shows SQL logs, /docs)

# AI Provider
AI_PROVIDER=groq                         # "groq" (free) or "claude"
GROQ_API_KEY=gsk_your-groq-key-here      # FREE key at https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=2000

# Claude (fallback)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# Database
# SQLite for local dev:
DATABASE_URL=sqlite:///./zareb.db
# PostgreSQL for production (Railway auto-provides this):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/zareb

# JWT
JWT_SECRET=replace-with-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SendGrid)
SENDGRID_API_KEY=                        # Get free key at https://sendgrid.com
SENDGRID_FROM_EMAIL=noreply@zareb.app

# CAPTCHA (Google reCAPTCHA v3)
RECAPTCHA_SECRET_KEY=                    # Get at https://www.google.com/recaptcha/admin

# Site & Admin
SITE_URL=https://zareb.netlify.app       # Frontend URL for magic links
ADMIN_EMAILS=                            # Comma-separated: admin1@email.com,admin2@email.com

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://zareb.netlify.app

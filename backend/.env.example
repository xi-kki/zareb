# Nuri Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nuri

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT
JWT_SECRET=replace-with-random-32-char-string
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://nuri.is-an-ai.dev

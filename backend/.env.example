# Zareb Backend Environment Variables
# ─────────────────────────────────────────

# AI Provider
AI_PROVIDER=groq                         # "groq" (free) or "claude"
GROQ_API_KEY=gsk_your-groq-key-here      # FREE key at https://console.groq.com
GROQ_MODEL=llama-3.1-70b-versatile
AI_MAX_TOKENS=2000

# Claude (fallback)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/zareb

# JWT
JWT_SECRET=replace-with-random-32-char-string
JWT_ALGORITHM=HS256

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
